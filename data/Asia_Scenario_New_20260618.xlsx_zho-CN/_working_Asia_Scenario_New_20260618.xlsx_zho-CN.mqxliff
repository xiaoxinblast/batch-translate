<trans-unit id="365" mq:status="Pretranslated" mq:segmentguid="029d960f-6a88-4118-8505-04797082113f" mq:lastchangedtimestamp="0001-01-01T00:00:00Z" mq:maxlengthchars="-1" mq:nosplitjoin="true" mq:firstlabel="364" mq:lastlabel="364" mq:autosplitjoinstate="0" mq:lastmodifrole="0" mq:multipleexactmatch="false">
<source xml:space="preserve" mq:segpart="364" mq:hasfollowingobject="hasfollowingobject">予知者は光 なら闇の力を使おうとしていた俺を<ph id="1">&lt;mq:ch val="
" /&gt;</ph>どう思って見てたんだろう？</source>
<target xml:space="preserve">预言者代表光——那他们又是如何看待<ph id="1">&lt;mq:ch val="
" /&gt;</ph>曾试图使用暗之力量的我呢？</target>
<context-group>
