<trans-unit id="371" mq:status="Pretranslated" mq:segmentguid="c9b19259-dc99-43bd-b101-4029a82eac67" mq:lastchangedtimestamp="0001-01-01T00:00:00Z" mq:maxlengthchars="-1" mq:nosplitjoin="true" mq:firstlabel="370" mq:lastlabel="370" mq:autosplitjoinstate="0" mq:lastmodifrole="0" mq:multipleexactmatch="false">
<source xml:space="preserve" mq:segpart="370" mq:hasfollowingobject="hasfollowingobject">なのに いつの間にかソラは別の未来を作り出していた</source>
<target xml:space="preserve">然而，不知何时索拉却创造出了另一个未来</target>
<context-group>
<context context-type="x-mmq-context">quattro_cutscene_qr7.07_070.vo_cn_qr_07070210_00_xehanort_1</context>
