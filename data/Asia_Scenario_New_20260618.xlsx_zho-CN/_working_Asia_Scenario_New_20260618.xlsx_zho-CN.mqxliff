<trans-unit id="372" mq:status="Pretranslated" mq:segmentguid="a9063798-2d78-44bd-ae67-ee12abf677d6" mq:lastchangedtimestamp="0001-01-01T00:00:00Z" mq:maxlengthchars="-1" mq:nosplitjoin="true" mq:firstlabel="371" mq:lastlabel="371" mq:autosplitjoinstate="0" mq:lastmodifrole="0" mq:multipleexactmatch="false">
<source xml:space="preserve" mq:segpart="371" mq:hasfollowingobject="hasfollowingobject">ソラが勝利し 俺が消滅した世界を</source>
<target xml:space="preserve">一个索拉获胜、而我消失的世界</target>
<context-group>
<context context-type="x-mmq-context">quattro_cutscene_qr7.07_070.vo_cn_qr_07070210_00_xehanort_2</context>
