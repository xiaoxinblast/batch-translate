<trans-unit id="368" mq:status="Pretranslated" mq:segmentguid="21045e63-7dd8-4840-9a12-70aff05e2d88" mq:lastchangedtimestamp="0001-01-01T00:00:00Z" mq:maxlengthchars="-1" mq:nosplitjoin="true" mq:firstlabel="367" mq:lastlabel="367" mq:autosplitjoinstate="0" mq:lastmodifrole="0" mq:multipleexactmatch="false">
<source xml:space="preserve" mq:segpart="367" mq:hasfollowingobject="hasfollowingobject">ほんとうは 俺はソラに勝ったんだよ</source>
<target xml:space="preserve">事实上，是我赢了索拉</target>
<context-group>
