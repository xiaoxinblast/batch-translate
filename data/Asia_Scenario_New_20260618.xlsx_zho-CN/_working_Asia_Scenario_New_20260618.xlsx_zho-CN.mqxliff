<trans-unit id="366" mq:status="Pretranslated" mq:segmentguid="e097335f-afe6-4dcf-a8ab-a2bfc98c04c2" mq:lastchangedtimestamp="0001-01-01T00:00:00Z" mq:maxlengthchars="-1" mq:nosplitjoin="true" mq:firstlabel="365" mq:lastlabel="365" mq:autosplitjoinstate="0" mq:lastmodifrole="0" mq:multipleexactmatch="false">
<source xml:space="preserve" mq:segpart="365" mq:hasfollowingobject="hasfollowingobject">なんとも想像はつかないな</source>
<target xml:space="preserve">完全无法想象啊</target>
