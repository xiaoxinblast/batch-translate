<trans-unit id="370" mq:status="Pretranslated" mq:segmentguid="50679778-97af-42bc-810d-0e4a0493b95e" mq:lastchangedtimestamp="0001-01-01T00:00:00Z" mq:maxlengthchars="-1" mq:nosplitjoin="true" mq:firstlabel="369" mq:lastlabel="369" mq:autosplitjoinstate="0" mq:lastmodifrole="0" mq:multipleexactmatch="false">
<source xml:space="preserve" mq:segpart="369" mq:hasfollowingobject="hasfollowingobject">俺はキングダムハーツという真の光を解放して<ph id="1">&lt;mq:ch val="
" /&gt;</ph>世界を壊し 作り直したはずなんだ</source>
<target xml:space="preserve">我解放了名为王国之心的真正光芒<ph id="1">&lt;mq:ch val="
" /&gt;</ph>本应毁灭了世界，再将其重塑</target>
<context-group>
<context context-type="x-mmq-context">quattro_cutscene_qr7.07_070.vo_cn_qr_07070190_00_xehanort_2</context>
